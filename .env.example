# =====================================================================
#  Service & Support Dashboard Pro — helloTV  |  Environment variables
# =====================================================================
#  Kopieer dit bestand naar  .env.local  en vul je eigen waarden in.
#  LET OP: dit zijn PLACEHOLDERS. Echte sleutels worden NIET door dit
#  prototype gegenereerd — die haal je uit het dashboard van elke dienst
#  (zie de link bij elke sleutel). Commit .env.local NOOIT naar GitHub.
# =====================================================================

# ---------- Supabase (database, auth, realtime) ----------
# Dashboard → Project Settings → API   (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://<jouw-project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
# Server-only. NOOIT in de browser/NEXT_PUBLIC gebruiken.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ---------- Cloudinary (foto's / bewijsmateriaal van defecten) ----------
# Dashboard → Settings → API Keys   (https://console.cloudinary.com)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="<cloud-name>"
CLOUDINARY_API_KEY="<api-key>"
CLOUDINARY_API_SECRET="<api-secret>"
# Maak een 'unsigned upload preset' aan voor uploads vanaf de klant.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="hellotv_repairs"

# ---------- AI-assistent (interne service-bot) ----------
# Kies één provider. Antigravity gebruikt Gemini; Anthropic kan ook.
GEMINI_API_KEY="<google-ai-studio-key>"          # https://aistudio.google.com/apikey
ANTHROPIC_API_KEY="<anthropic-key>"              # https://console.anthropic.com  (optioneel)

# ---------- Servicepartner-integraties (Fase 3) ----------
# Vul aan zodra de koppelingen door Commerced / het merk zijn opgeleverd.
CEREPAIR_API_BASE="https://api.ce-repair.example"
CEREPAIR_API_KEY="<partner-key>"
# Per merk komt hier een eigen sleutel/endpoint bij (Sonos, Samsung, LG, …).

# ---------- VMS / Magento / Vendit (bestaande systemen) ----------
VMS_API_BASE="https://<vms-endpoint>"
VMS_API_KEY="<vms-key>"
VENDIT_API_BASE="https://<vendit-endpoint>"      # voorraad per filiaal
VENDIT_API_KEY="<vendit-key>"

# ---------- Deploy (Vercel) ----------
# Vercel-deploys gaan via de Vercel-UI of CLI; een token is alleen nodig
# voor scripted deploys.  Account → Settings → Tokens
VERCEL_TOKEN="<optioneel-vercel-token>"

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
